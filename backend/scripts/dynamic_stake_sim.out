===============================================================================================
PIECEWISE FUNCTION (recommended)
===============================================================================================
def dynamic_cap_pct(bankroll):
    if bankroll < 250: return 0.100  # $100 tier
    elif bankroll < 500: return 0.050  # $250 tier
    elif bankroll < 1000: return 0.080  # $500 tier
    elif bankroll < 2500: return 0.150  # $1000 tier
    elif bankroll < 5000: return 0.150  # $2500 tier
    elif bankroll < 10000: return 0.100  # $5000 tier
    elif bankroll < 20000: return 0.080  # $10000 tier
    else: return 0.100  # $20000+ tier

def dynamic_max_kelly(bankroll):
    if bankroll < 250: return 0.50  # $100 tier
    elif bankroll < 500: return 0.75  # $250 tier
    elif bankroll < 1000: return 0.75  # $500 tier
    elif bankroll < 2500: return 1.00  # $1000 tier
    elif bankroll < 5000: return 0.75  # $2500 tier
    elif bankroll < 10000: return 0.75  # $5000 tier
    elif bankroll < 20000: return 0.75  # $10000 tier
    else: return 0.75  # $20000+ tier
