# Environment variables
# Copy this file to .env and fill in your actual values

# Anthropic API Key for Claude LLM integration
ANTHROPIC_API_KEY=your_api_key_here

# Chrome profile directory for persistent sessions (optional)
# Chrome stores cookies/logins here so BankID sessions survive restarts.
# Default: %LOCALAPPDATA%\Arnold\chrome-profile
# CHROME_PROFILE_DIR=C:\Users\YourName\Arnold\chrome-profile

# Brave Search API Key for LLM boost probability research (optional)
# Get a free key at https://api.search.brave.com/
# Without this, LLM research uses Claude's knowledge only (no live search).
# BRAVE_API_KEY=your_brave_api_key_here

# Pinnacle login credentials (optional, for auto-login)
# Pinnacle uses email/password (no BankID), so we can auto-login.
# PINNACLE_EMAIL=your_email@example.com
# PINNACLE_PASSWORD=your_password_here
